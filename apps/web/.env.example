NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Upstash Redis (Vercel Marketplace 통합)
# View counter 저장소로 사용. 미설정 시 view count는 0으로 표시되고 increment는 스킵됨.
KV_REST_API_URL=https://your-redis.upstash.io
KV_REST_API_TOKEN=your-rest-api-token

# 본인 제외 시크릿 — /admin/exclude-views?key=<이 값>으로 쿠키 설정
# 32바이트 이상의 무작위 hex 문자열 권장: `openssl rand -hex 32`
EXCLUDE_VIEWS_SECRET=your-32-byte-hex-secret
